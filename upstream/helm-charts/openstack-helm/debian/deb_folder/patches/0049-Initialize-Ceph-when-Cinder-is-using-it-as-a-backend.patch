From 7278211d8a4a658cc7118f00f25b27b2fccd1a32 Mon Sep 17 00:00:00 2001
From: Thiago Miranda <tmarques@windriver.com>
Date: Thu, 19 Feb 2026 19:41:22 -0300
Subject: [PATCH] Initialize Ceph when Cinder is using it as a backend

This commit enables Glance to properly initialize Ceph configuration
when using Cinder as its backend and Cinder uses Ceph for storage.

Changes:
--------
1. Added CINDER_USES_CEPH environment variable to control Ceph
   initialization based on Cinder's backend configuration

2. Modified storage-init.sh to initialize Ceph pools and verify
   connectivity when storage backend is "cinder" and Cinder uses Ceph

3. Added ceph-cinder-keyring mounting in deployment-api.yaml:
   - Mounts Cinder's Ceph keyring from secret (rbd_cinder)
   - Only mounted when storage is "cinder" and cinder_uses_ceph is true
   - Enables Glance to authenticate with Ceph via Cinder credentials

4. Updated ceph-keyring.sh to generate ceph.client.cinder.keyring
   when CINDER_USES_CEPH is enabled

5. Extended conditional checks throughout templates to include
   Cinder+Ceph scenario alongside existing RBD storage backend

This allows Glance to leverage Ceph storage through Cinder while
maintaining proper authentication and pool initialization.

Signed-off-by: Thiago Miranda <tmarques@windriver.com>
---
 glance/templates/bin/_ceph-keyring.sh.tpl |  7 +++++++
 glance/templates/bin/_storage-init.sh.tpl |  4 ++--
 glance/templates/deployment-api.yaml      | 19 ++++++++++++++++---
 glance/templates/job-storage-init.yaml    | 10 ++++++----
 glance/values.yaml                        |  3 +++
 5 files changed, 34 insertions(+), 9 deletions(-)

diff --git a/glance/templates/bin/_ceph-keyring.sh.tpl b/glance/templates/bin/_ceph-keyring.sh.tpl
index cbafe3d3f..88f7db39c 100644
--- a/glance/templates/bin/_ceph-keyring.sh.tpl
+++ b/glance/templates/bin/_ceph-keyring.sh.tpl
@@ -22,4 +22,11 @@ cat > /etc/ceph/ceph.client.${RBD_STORE_USER}.keyring <<EOF
     key = $(cat /tmp/client-keyring)
 EOF
 
+if [ "x$CINDER_USES_CEPH" == "xtrue" ]; then
+  cat > /etc/ceph/ceph.client.cinder.keyring <<EOF
+[client.cinder]
+    key = $(cat /tmp/client-cinder-keyring)
+EOF
+fi
+
 exit 0
diff --git a/glance/templates/bin/_storage-init.sh.tpl b/glance/templates/bin/_storage-init.sh.tpl
index 53ba9f155..dbda2edfa 100644
--- a/glance/templates/bin/_storage-init.sh.tpl
+++ b/glance/templates/bin/_storage-init.sh.tpl
@@ -15,7 +15,7 @@ limitations under the License.
 */}}
 
 set -x
-if [ "x$STORAGE_BACKEND" == "xrbd" ]; then
+if [ "x$STORAGE_BACKEND" == "xrbd" ] || ([ "x$STORAGE_BACKEND" == "xcinder" ] && [ "x$CINDER_USES_CEPH" == "xtrue" ]); then
   SECRET=$(mktemp --suffix .yaml)
   KEYRING=$(mktemp --suffix .keyring)
   function cleanup {
@@ -41,7 +41,7 @@ elif [ "x$STORAGE_BACKEND" == "xswift" ]; then
   curl --fail -i -X POST "${OS_SWIFT_SCOPED_ENDPOINT}" \
     -H "X-Auth-Token: ${OS_TOKEN}" \
     -H "X-Account-Meta-Temp-URL-Key: ${SWIFT_TMPURL_KEY}"
-elif [ "x$STORAGE_BACKEND" == "xrbd" ]; then
+elif [ "x$STORAGE_BACKEND" == "xrbd" ] || ([ "x$STORAGE_BACKEND" == "xcinder" ] && [ "x$CINDER_USES_CEPH" == "xtrue" ]); then
   ceph -s
   function ensure_pool () {
     if [ "$2" -eq 0 ]; then
