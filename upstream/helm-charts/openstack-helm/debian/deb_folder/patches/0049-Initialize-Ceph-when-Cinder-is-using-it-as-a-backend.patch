 {{- end }}
-{{- if eq .Values.storage "rbd" }}
+{{- if or (eq .Values.storage "rbd") (and (eq .Values.storage "cinder") (.Values.conf.cinder.cinder_uses_ceph)) }}
         - name: etcceph
           emptyDir: {}
         - name: ceph-etc
@@ -301,6 +309,11 @@ spec:
         - name: ceph-keyring
           secret:
             secretName: {{ .Values.secrets.rbd | quote }}
