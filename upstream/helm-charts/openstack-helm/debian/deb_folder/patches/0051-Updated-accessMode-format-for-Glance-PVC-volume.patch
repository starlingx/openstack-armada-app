From e13467144e463611e648dab5e7064ae9aefd3e5e Mon Sep 17 00:00:00 2001
From: jbarboza <joaopedro.barbozalioneza@windriver.com>
Date: Tue, 31 Mar 2026 11:42:46 -0300
Subject: [PATCH] Updated accessMode format for Glance PVC volume

Signed-off-by: jbarboza <joaopedro.barbozalioneza@windriver.com>
---
 glance/templates/pvc-images.yaml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/glance/templates/pvc-images.yaml b/glance/templates/pvc-images.yaml
index 9451a959e..f6116a9e5 100644
--- a/glance/templates/pvc-images.yaml
+++ b/glance/templates/pvc-images.yaml
@@ -25,7 +25,7 @@ metadata:
     helm.sh/resource-policy: keep
   {{- end }}
 spec:
-  accessModes: {{ .Values.volume.accessModes }}
+  accessModes: {{- toYaml $pvcVolume.access_modes | nindent 4 }}
   resources:
     requests:
       storage: {{ .Values.volume.size }}
-- 
