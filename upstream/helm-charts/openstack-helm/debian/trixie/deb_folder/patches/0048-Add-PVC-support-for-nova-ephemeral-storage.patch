+++ b/libvirt/templates/daemonset-libvirt.yaml
@@ -33,6 +33,9 @@ exec:
 
 {{- $mounts_libvirt := .Values.pod.mounts.libvirt.libvirt }}
 {{- $mounts_libvirt_init := .Values.pod.mounts.libvirt.init_container }}
+{{- $storageConf := (.Values.storage_conf | default dict) }}
+{{- $pvc := ($storageConf.pvc | default dict) }}
+{{- $pvcEnabled := ($pvc.enabled | default false) }}
 
 ---
 apiVersion: apps/v1
@@ -280,6 +283,9 @@ spec:
             {{- if .Values.storage_conf.nfs_shares.enabled }}
             - name: nfsnovainstances
               mountPath: {{ .Values.storage_conf.nfs_shares.instances_path }}
+            {{- else if $pvcEnabled }}
+            - name: pvcnovainstances
+              mountPath: {{ $pvc.instances_path }}
             {{- end }}
             - name: run
               mountPath: /run
@@ -371,6 +377,10 @@ spec:
           nfs:
             server: {{ .Values.storage_conf.nfs_shares.server }}
             path: {{ .Values.storage_conf.nfs_shares.path }}
+        {{- else if $pvcEnabled }}
+        - name: pvcnovainstances
+          persistentVolumeClaim:
+            claimName: {{ $pvc.name }}
         {{- end }}
         - name: run
           hostPath:
