diff --git a/nova/templates/pvc-nova-ephemeral.yaml b/nova/templates/pvc-nova-ephemeral.yaml
new file mode 100644
index 0000000..bfc7924
--- /dev/null
+++ b/nova/templates/pvc-nova-ephemeral.yaml
@@ -0,0 +1,23 @@
+{{/*
+Copyright (c) 2026 Wind River Systems, Inc.
+
+SPDX-License-Identifier: Apache-2.0
+
+*/}}
+{{- $storageConf := (.Values.storage_conf | default dict) -}}
+{{- $pvc := ($storageConf.pvc | default dict) -}}
+{{- $pvcVolume := ($pvc.volume | default dict) -}}
+{{- $pvcEnabled := ($pvc.enabled | default false) -}}
+{{- if $pvcEnabled }}
+apiVersion: v1
+kind: PersistentVolumeClaim
+metadata:
+  name: {{ $pvc.name }}
+spec:
+  accessModes:
+{{- toYaml $pvcVolume.access_modes | nindent 4 }}
+  resources:
+    requests:
+      storage: {{ $pvcVolume.size }}
+  storageClassName: {{ $pvcVolume.class_name | quote }}
+{{- end }}
diff --git a/nova/values.yaml b/nova/values.yaml
index a4a5b91..e907cb0 100644
--- a/nova/values.yaml
+++ b/nova/values.yaml
@@ -2718,19 +2718,39 @@ tls:
   oslo_db: false
 
 storage_conf:
-  # This list is for compatibility with other charts.
   storage_backends:
     - name: host-path
       enabled: true
     - name: nfs
       enabled: true
+    - name: pvc
+      enabled: true
   volume_storage_class_priority:
     - host-path
     - nfs
+    - pvc
   nfs_shares:
     enabled: false
     server: 127.0.0.1
     path: /openstack_instances
+  pvc:
+    name: "nova-instances"
+    enabled: false
+    instances_path: /var/lib/instances
+    volume:
+      class_name: general
+      size: 10Gi
+      access_modes:
+        - ReadWriteMany
+    storage_backends:
+      - name: netapp-nfs
+        enabled: true
+    # Ordered list of backend names to use when selecting a storage class for
+    # PVC provisioning. Accepts arbitrary backend name strings matching entries
+    # in storage_backends above — not limited to netapp-nfs. Defaults to
+    # [netapp-nfs] for backward compatibility.
+    storage_class_priority:
+      - netapp-nfs
 
 manifests:
   certificates: false
