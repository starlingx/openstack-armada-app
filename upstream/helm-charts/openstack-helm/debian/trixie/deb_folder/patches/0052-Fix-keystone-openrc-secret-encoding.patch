From 7ac5b7ce5032ccc841ce9fa55c39c8a4a5b20fbf Mon Sep 17 00:00:00 2001
From: Daniel Caires <DanielMarques.Caires@windriver.com>
Date: Tue, 14 Apr 2026 14:54:47 -0300
Subject: [PATCH] Fix keystone openrc secret encoding

During the OSH package upversion to the gazpacho release,
deployment was failing to read some of the configurations
generated by the helm plugin. These configs were not being
generated as a string, and when passed directly to b64enc,
the encoding would fail.

This patch adds a toString filter before b64enc in the
keystone_secret_openrc template to ensure all values are
properly converted to strings before base64 encoding.

Change-Id: Ibee011a3f82f353cb5dc0f950ccdf4d0bcadd2b3
---
 .../snippets/_keystone_secret_openrc.tpl       | 18 +++++++++---------
 1 file changed, 9 insertions(+), 9 deletions(-)

diff --git a/helm-toolkit/templates/snippets/_keystone_secret_openrc.tpl b/helm-toolkit/templates/snippets/_keystone_secret_openrc.tpl
index f6276576c..1a20fcd2b 100644
--- a/helm-toolkit/templates/snippets/_keystone_secret_openrc.tpl
+++ b/helm-toolkit/templates/snippets/_keystone_secret_openrc.tpl
@@ -18,15 +18,15 @@ limitations under the License.
 {{- $context := index . 2 -}}
 {{- $userContext := index $context.Values.endpoints.identity.auth $userClass }}
 OS_AUTH_URL: {{ tuple "identity" $identityEndpoint "api" $context | include "helm-toolkit.endpoints.keystone_endpoint_uri_lookup" | b64enc }}
-OS_REGION_NAME: {{ $userContext.region_name | b64enc }}
-OS_INTERFACE: {{ $userContext.interface | default "internal" | b64enc }}
-OS_PROJECT_DOMAIN_NAME: {{ $userContext.project_domain_name | b64enc }}
-OS_PROJECT_NAME: {{ $userContext.project_name | b64enc }}
-OS_USER_DOMAIN_NAME: {{ $userContext.user_domain_name | b64enc }}
-OS_USERNAME: {{ $userContext.username | b64enc }}
-OS_PASSWORD: {{ $userContext.password | b64enc }}
-OS_DEFAULT_DOMAIN: {{ $userContext.default_domain_id | default "default" | b64enc }}
+OS_REGION_NAME: {{ $userContext.region_name | toString | b64enc }}
+OS_INTERFACE: {{ $userContext.interface | default "internal" | toString | b64enc }}
+OS_PROJECT_DOMAIN_NAME: {{ $userContext.project_domain_name | toString | b64enc }}
+OS_PROJECT_NAME: {{ $userContext.project_name | toString | b64enc }}
+OS_USER_DOMAIN_NAME: {{ $userContext.user_domain_name | toString | b64enc }}
+OS_USERNAME: {{ $userContext.username | toString | b64enc }}
+OS_PASSWORD: {{ $userContext.password | toString | b64enc }}
+OS_DEFAULT_DOMAIN: {{ $userContext.default_domain_id | default "default" | toString | b64enc }}
 {{- if $userContext.cacert }}
-OS_CACERT: {{ $userContext.cacert | b64enc }}
+OS_CACERT: {{ $userContext.cacert | toString | b64enc }}
 {{- end }}
 {{- end }}
-- 
2.34.1

