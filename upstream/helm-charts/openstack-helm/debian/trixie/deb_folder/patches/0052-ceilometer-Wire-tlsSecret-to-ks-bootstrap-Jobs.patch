From 3170a4663cf6095b92065572afd4580b06eb2980 Mon Sep 17 00:00:00 2001
From: Mateus Nascimento <mateus.soaresdonascimento@windriver.com>
Date: Wed, 27 May 2026 14:56:13 -0300
Subject: [PATCH] ceilometer: Wire TLS CA into bootstrap Jobs and runtime pods

Wire keystone-tls-public into the ceilometer chart so HTTPS
deployments can verify Keystone and per-service catalog endpoints.
Gated on manifests.certificates.

* job-ks-user.yaml: pass tlsSecret to the helm-toolkit job_ks_user
  template. This openstack-helm revision no longer ships the
  ceilometer ks-service / ks-endpoints job templates, so only the
  ks-user job is wired here.
* daemonset-compute.yaml, deployment-central.yaml,
  deployment-notification.yaml: mount the secret's ca.crt on the
  runtime pods.

Signed-off-by: Mateus Nascimento <mateus.soaresdonascimento@windriver.com>
---
 ceilometer/templates/daemonset-compute.yaml       | 2 ++
 ceilometer/templates/deployment-central.yaml      | 2 ++
 ceilometer/templates/deployment-notification.yaml | 2 ++
 ceilometer/templates/job-ks-user.yaml             | 3 +++
 4 files changed, 9 insertions(+)

diff --git a/ceilometer/templates/daemonset-compute.yaml b/ceilometer/templates/daemonset-compute.yaml
index 07536d443..0a6be88eb 100644
--- a/ceilometer/templates/daemonset-compute.yaml
+++ b/ceilometer/templates/daemonset-compute.yaml
@@ -116,6 +116,7 @@ spec:
               mountPath: /etc/machine-id
               readOnly: true
 {{ if $mounts_ceilometer_compute.volumeMounts }}{{ toYaml $mounts_ceilometer_compute.volumeMounts | indent 12 }}{{ end }}
+{{- dict "enabled" .Values.manifests.certificates "name" "keystone-tls-public" "ca" true | include "helm-toolkit.snippets.tls_volume_mount" | indent 12 }}
       volumes:
         - name: pod-tmp
           emptyDir: {}
@@ -145,4 +146,5 @@ spec:
           hostPath:
             path: /etc/machine-id
 {{ if $mounts_ceilometer_compute.volumes }}{{ toYaml $mounts_ceilometer_compute.volumes | indent 8 }}{{ end }}
+{{- dict "enabled" .Values.manifests.certificates "name" "keystone-tls-public" | include "helm-toolkit.snippets.tls_volume" | indent 8 }}
 {{- end }}
diff --git a/ceilometer/templates/deployment-central.yaml b/ceilometer/templates/deployment-central.yaml
index 15fae9591..8c147bbaa 100644
--- a/ceilometer/templates/deployment-central.yaml
+++ b/ceilometer/templates/deployment-central.yaml
@@ -103,6 +103,7 @@ spec:
               subPath: ceilometer-central.sh
               readOnly: true
 {{ if $mounts_ceilometer_central.volumeMounts }}{{ toYaml $mounts_ceilometer_central.volumeMounts | indent 12 }}{{ end }}
+{{- dict "enabled" .Values.manifests.certificates "name" "keystone-tls-public" "ca" true | include "helm-toolkit.snippets.tls_volume_mount" | indent 12 }}
       volumes:
         - name: pod-tmp
           emptyDir: {}
@@ -117,4 +118,5 @@ spec:
             name: ceilometer-bin
             defaultMode: 0555
 {{ if $mounts_ceilometer_central.volumes }}{{ toYaml $mounts_ceilometer_central.volumes | indent 8 }}{{ end }}
+{{- dict "enabled" .Values.manifests.certificates "name" "keystone-tls-public" | include "helm-toolkit.snippets.tls_volume" | indent 8 }}
 {{- end }}
diff --git a/ceilometer/templates/deployment-notification.yaml b/ceilometer/templates/deployment-notification.yaml
index 33b2c382c..dd9d590a6 100644
--- a/ceilometer/templates/deployment-notification.yaml
+++ b/ceilometer/templates/deployment-notification.yaml
@@ -105,6 +105,7 @@ spec:
               subPath: ceilometer-notification.sh
               readOnly: true
 {{ if $mounts_ceilometer_notification.volumeMounts }}{{ toYaml $mounts_ceilometer_notification.volumeMounts | indent 12 }}{{ end }}
+{{- dict "enabled" .Values.manifests.certificates "name" "keystone-tls-public" "ca" true | include "helm-toolkit.snippets.tls_volume_mount" | indent 12 }}
       volumes:
         - name: pod-tmp
           emptyDir: {}
@@ -121,4 +122,5 @@ spec:
             name: ceilometer-bin
             defaultMode: 0555
 {{ if $mounts_ceilometer_notification.volumes }}{{ toYaml $mounts_ceilometer_notification.volumes | indent 8 }}{{ end }}
+{{- dict "enabled" .Values.manifests.certificates "name" "keystone-tls-public" | include "helm-toolkit.snippets.tls_volume" | indent 8 }}
 {{- end }}
diff --git a/ceilometer/templates/job-ks-user.yaml b/ceilometer/templates/job-ks-user.yaml
index df49722ee..86a4a6464 100644
--- a/ceilometer/templates/job-ks-user.yaml
+++ b/ceilometer/templates/job-ks-user.yaml
@@ -14,6 +14,9 @@ limitations under the License.
 
 {{- if .Values.manifests.job_ks_user }}
 {{- $ksUserJob := dict "envAll" . "serviceName" "ceilometer" -}}
+{{- if .Values.manifests.certificates -}}
+{{- $_ := set $ksUserJob "tlsSecret" "keystone-tls-public" -}}
+{{- end -}}
 {{- if .Values.pod.tolerations.ceilometer.enabled -}}
 {{- $_ := set $ksUserJob "tolerationsEnabled" true -}}
 {{- end -}}
--
