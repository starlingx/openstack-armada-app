diff --git a/ceilometer/templates/servicemonitor-central.yaml b/ceilometer/templates/servicemonitor-central.yaml
new file mode 100644
index 000000000..75fb908c5
--- /dev/null
+++ b/ceilometer/templates/servicemonitor-central.yaml
@@ -0,0 +1,37 @@
