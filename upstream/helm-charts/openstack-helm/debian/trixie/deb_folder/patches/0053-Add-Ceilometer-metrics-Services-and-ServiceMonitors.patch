+{{- if .Values.manifests.service_central_metrics }}
+apiVersion: v1
+kind: Service
+metadata:
+  name: {{ printf "%s-%s" .Release.Name "central" | trunc 63 | trimSuffix "-" }}
+  namespace: {{ .Release.Namespace }}
+  labels:
+    app: ceilometer-central
+spec:
+  clusterIP: None        # headless — avoids load-balancing, lists all endpoints
+  selector:
+    application: ceilometer
+    component: central
+  ports:
+    - name: metrics
+      port: 9101
+      targetPort: 9101
+      protocol: TCP
+{{- end }}
