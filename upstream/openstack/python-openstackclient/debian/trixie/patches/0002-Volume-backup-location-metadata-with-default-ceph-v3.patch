From 333888d20587b2cc3acf9dca6616ca113440c8e3 Mon Sep 17 00:00:00 2001
From: cbohlhal <Caique.BohlhalterdeSouza@windriver.com>
Date: Tue, 5 May 2026 22:41:32 -0400
Subject: [PATCH] Volume backup location metadata with default ceph (v3)

Add location handling to volume backup create/show in v3, propagating
via --property and metadata when microversion >= 3.43.
Set default location "ceph" for STX/vanilla compatibility when
--location is absent and inject it into metadata when supported.
Update v3 fakes and tests to cover location, metadata, and defaults.
v2 no longer exposes location or related columns; the feature is
now restricted to v3.

Signed-off-by: cbohlhal <Caique.BohlhalterdeSouza@windriver.com>
[ Ported this patch to python-openstackclient v9.0.0-3 @ Gazpacho ]
Adapted for 9.0.0 SDK fakes (generate_fake_resource replaces
create_one_backup helper). Removed v3/fakes.py change as location
attribute is now auto-generated by SDK fakes.
Signed-off-by: Yathavan Parameshwaran <Yathavan.Parameshwaran@windriver.com>
---
 .../unit/volume/v3/test_volume_backup.py      | 11 +++++++++-
 openstackclient/volume/v3/volume_backup.py    | 22 +++++++++++++++++++
 2 files changed, 32 insertions(+), 1 deletion(-)

diff --git a/openstackclient/tests/unit/volume/v3/test_volume_backup.py b/openstackclient/tests/unit/volume/v3/test_volume_backup.py
index 86bde78..137a12e 100644
--- a/openstackclient/tests/unit/volume/v3/test_volume_backup.py
+++ b/openstackclient/tests/unit/volume/v3/test_volume_backup.py
@@ -28,6 +28,7 @@ from openstackclient.volume.v3 import volume_backup
 class TestBackupCreate(volume_fakes.TestVolume):
     columns = (
         'id',
+        'location',
         'name',
         'volume_id',
     )
@@ -48,6 +49,7 @@ class TestBackupCreate(volume_fakes.TestVolume):
 
         self.data = (
             self.backup.id,
+            self.backup.location,
             self.backup.name,
             self.backup.volume_id,
         )
@@ -89,6 +91,7 @@ class TestBackupCreate(volume_fakes.TestVolume):
             force=True,
             is_incremental=True,
             snapshot_id=self.backup.snapshot_id,
+            location="ceph",
         )
         self.assertEqual(self.columns, columns)
         self.assertEqual(self.data, data)
@@ -118,7 +121,8 @@ class TestBackupCreate(volume_fakes.TestVolume):
             description=None,
             force=False,
             is_incremental=False,
-            metadata={"foo": "bar", "wow": "much-cool"},
+            location="ceph",
+            metadata={"foo": "bar", "wow": "much-cool", "location": "ceph"},
         )
         self.assertEqual(self.columns, columns)
         self.assertEqual(self.data, data)
@@ -167,6 +171,8 @@ class TestBackupCreate(volume_fakes.TestVolume):
             description=None,
             force=False,
             is_incremental=False,
+            location="ceph",
+            metadata={"location": "ceph"},
             availability_zone="my-az",
         )
         self.assertEqual(self.columns, columns)
@@ -215,6 +221,7 @@ class TestBackupCreate(volume_fakes.TestVolume):
             description=self.backup.description,
             force=False,
             is_incremental=False,
+            location="ceph",
         )
         self.assertEqual(self.columns, columns)
         self.assertEqual(self.data, data)
@@ -859,6 +866,7 @@ class TestBackupShow(volume_fakes.TestVolume):
         "fail_reason",
         "has_dependent_backups",
         "id",
+        "location",
         "is_incremental",
         "metadata",
         "name",
@@ -888,6 +896,7 @@ class TestBackupShow(volume_fakes.TestVolume):
             self.backup.fail_reason,
             self.backup.has_dependent_backups,
             self.backup.id,
+            self.backup.location,
             self.backup.is_incremental,
             self.backup.metadata,
             self.backup.name,
diff --git a/openstackclient/volume/v3/volume_backup.py b/openstackclient/volume/v3/volume_backup.py
index 2ab24f3..6739d6c 100644
--- a/openstackclient/volume/v3/volume_backup.py
+++ b/openstackclient/volume/v3/volume_backup.py
@@ -86,6 +86,11 @@ class CreateVolumeBackup(command.ShowOne):
             metavar="<snapshot>",
             help=_("Snapshot to backup (name or ID)"),
         )
+        parser.add_argument(
+            "--location",
+            metavar="<location>",
+            help=_("Optional backup location")
+        )
         parser.add_argument(
             '--force',
             action='store_true',
@@ -161,8 +166,23 @@ class CreateVolumeBackup(command.ShowOne):
 
             kwargs['availability_zone'] = parsed_args.availability_zone
 
+        if not parsed_args.location:
+            if parsed_args.properties:
+                parsed_args.location = parsed_args.properties.get(
+                    "location", "ceph"
+                )
+            else:
+                parsed_args.location = "ceph"
+
+        if sdk_utils.supports_microversion(volume_client, '3.43'):
+            if kwargs.get('metadata', None):
+                kwargs['metadata']['location'] = parsed_args.location
+            else:
+                kwargs['metadata'] = {'location': parsed_args.location}
+
         columns: tuple[str, ...] = (
             "id",
+            "location",
             "name",
             "volume_id",
         )
@@ -173,6 +193,7 @@ class CreateVolumeBackup(command.ShowOne):
             description=parsed_args.description,
             force=parsed_args.force,
             is_incremental=parsed_args.incremental,
+            location=parsed_args.location,
             **kwargs,
         )
         data = utils.get_dict_properties(backup, columns)
@@ -684,6 +705,7 @@ class ShowVolumeBackup(command.ShowOne):
             "fail_reason",
             "has_dependent_backups",
             "id",
+            "location",
             "is_incremental",
             "metadata",
             "name",
-- 
2.43.0

