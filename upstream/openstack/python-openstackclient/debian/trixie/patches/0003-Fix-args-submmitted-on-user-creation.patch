From 231a9b9533c386e08f4cf9d0f9892cca13400d8c Mon Sep 17 00:00:00 2001
From: Doug Goldstein <cardoe@cardoe.com>
Date: Mon, 15 Dec 2025 10:14:41 -0600
Subject: [PATCH] Fix args submmitted on user creation

When a user is created without a password then no parameter called
'password' should be submitted to the keystone API. This removes the
incorrect 'password' with null being supplied.

Note: This backport may no longer be necessary in future upgrades,
as the fix is already present starting from
python-openstackclient 8.2.0-49.

Change-Id: If1c2eb5db360764a5f7660ce4e5353da85b6d3da

[Backport fix to avoid sending null password on user creation]
Signed-off-by: cbohlhal <Caique.BohlhalterdeSouza@windriver.com>
---
 openstackclient/identity/v3/user.py           |  6 ++-
 .../tests/unit/identity/v3/test_user.py       | 41 -------------------
 2 files changed, 4 insertions(+), 43 deletions(-)

diff --git a/openstackclient/identity/v3/user.py b/openstackclient/identity/v3/user.py
index 545b1cda..715bc797 100644
--- a/openstackclient/identity/v3/user.py
+++ b/openstackclient/identity/v3/user.py
@@ -288,13 +288,16 @@ class CreateUser(command.ShowOne):
         elif parsed_args.password_prompt:
             password = utils.get_password(self.app.stdin)
 
-        if not parsed_args.password:
+        if not password:
             LOG.warning(
                 _(
                     "No password was supplied, authentication will fail "
                     "when a user does not have a password."
                 )
             )
+        else:
+            kwargs['password'] = password
+
         options = _get_options_for_user(identity_client, parsed_args)
         if options:
             kwargs['options'] = options
@@ -303,7 +306,6 @@ class CreateUser(command.ShowOne):
             user = identity_client.create_user(
                 is_enabled=is_enabled,
                 name=parsed_args.name,
-                password=password,
                 **kwargs,
             )
         except sdk_exc.ConflictException:
